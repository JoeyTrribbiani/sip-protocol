{
  "name": "sip-protocol",
  "version": "1.0.0",
  "description": "Swarm Intelligence Protocol (SIP) - 基于Signal Double Ratchet的多Agent端到端加密通信协议",
  "main": "src/index.js",
  "scripts": {
    "test": "node tests/test_sip_protocol.js",
    "test:unit": "node tests/unit/test_*.js",
    "test:integration": "node tests/integration/test_*.js",
    "test:e2e": "node tests/e2e/test_*.js",
    "test:watch": "nodemon --exec 'npm test'",
    "example:handshake": "node examples/basic_handshake.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "precommit": "npm run lint && npm test"
  },
  "keywords": [
    "e2ee",
    "end-to-end-encryption",
    "signal-protocol",
    "double-ratchet",
    "multi-agent",
    "swarm-intelligence",
    "cryptography",
    "secure-communication"
  ],
  "author": "Joey Tribbiani",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/ciphers": "^0.5.0",
    "argon2": "^0.44.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JoeyTrribbiani/sip-protocol"
  }
}
